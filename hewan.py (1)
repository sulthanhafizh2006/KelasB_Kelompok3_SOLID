# Class hewan
class Hewan(ABC):
    def __init__(self, nama):
        self.nama = nama

    @abstractmethod
    def makan(self):
        pass

# Interface khusus hewan yang bisa terbang
class BisaTerbang(ABC):
    @abstractmethod
    def terbang(self):
        pass

# Hewan biasa atau gabisa terbang
class Singa(Hewan):
    def makan(self):
        print(f"{self.nama} sedang makan daging.")

# Hewan yang bisa terbang
class Burung(Hewan, BisaTerbang):
    def makan(self):
        print(f"{self.nama} sedang makan biji-bijian.")

    def terbang(self):
        print(f"{self.nama} sedang terbang.")
